# Copy to .env.local (gitignored) and fill in. Never commit real secrets.

# Server-only. Used for Gemini Live ephemeral token minting and the optional
# gemini-embedding photo-upload feature. NEVER exposed to the browser.
GEMINI_API_KEY=

# Local services (defaults match docker-compose.yml + `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
CHROMA_URL=http://localhost:8000

# Model ids — set to match what you pulled via `ollama list`.
GEMMA_MODEL=gemma4:e4b
# Local embeddings — keeps episodic vector search on the offline path.
EMBED_MODEL=embeddinggemma
# Current Gemini Live model id drifts fast — verify on ai.google.dev.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# Feature flags
# false (default) = route by input channel, no LLM routing hop.
USE_LLM_ROUTER=false
# true only on a 32GB+ Mac — sets OLLAMA_USE_MLX at service launch.
USE_MLX=false

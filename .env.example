# Copy to .env.local (gitignored) and fill in. Never commit real secrets.

# Server-only. Used for Gemini Live ephemeral token minting and the optional
# gemini-embedding-2 photo-upload stretch feature. NEVER exposed to the browser.
GEMINI_API_KEY=

# Local services (defaults match docker-compose.yml + `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
CHROMA_URL=http://localhost:8000

# Model ids — set after `ollama list` on the demo Mac.
# 32GB+ Mac: gemma4:12b-mlx (with USE_MLX=true below). 16GB Mac: gemma4:12b (llama.cpp Metal).
GEMMA_MODEL=gemma4:12b
# Local embeddings — keeps episodic vector search on the offline read/write path (doc 10 B1).
EMBED_MODEL=embeddinggemma
# Current Gemini Live model id drifts fast — verify on ai.google.dev before the demo.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# Feature flags
# false (default) = route by input channel, no LLM routing hop (doc 10 B4/B9/B15).
USE_LLM_ROUTER=false
# true only on a 32GB+ Mac — sets OLLAMA_USE_MLX at service launch (doc 10 decision 6).
USE_MLX=false
